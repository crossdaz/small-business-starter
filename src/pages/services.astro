---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Banner from '../components/Banner.astro';
import CTA from '../components/CTA.astro';
import { brand } from '../config/brand';

const services = [
  {
    title: 'Full House Rewires',
    description: 'Complete electrical rewiring for older properties to modern safety standards. We handle everything from planning to testing.',
  },
  {
    title: 'Socket & Lighting Installation',
    description: 'New sockets, switches, LED lighting, outdoor lighting, and smart home wiring. All work carried out to current regulations.',
  },
  {
    title: 'Fault Finding & Repairs',
    description: 'Fast diagnosis and repair of electrical faults. From tripping circuits to no power — we find and fix the problem quickly.',
  },
  {
    title: 'Consumer Unit Upgrades',
    description: 'Replace old fuse boxes with modern consumer units (RCBOs) for improved safety and compliance.',
  },
  {
    title: 'EV Charger Installation',
    description: 'Safe and certified electric vehicle charger installations for home and business.',
  },
  {
    title: 'Landlord Safety Certificates',
    description: 'EICR reports and Electrical Installation Condition Reports for rental properties.',
  },
];
---

<BaseLayout title="Services" description={`Explore the full range of electrical services offered by ${brand.name}.`}>
  <Header slot="header" />
  <Banner title="Our Services" />
  
  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">Electrical Services You Can Trust</h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          From minor repairs to full rewires — professional, reliable electrical work for homes and businesses.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {services.map((service) => (
          <div class="flex gap-5 rounded-lg border border-border bg-background p-6 shadow-sm">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              ⚡
            </div>
            <div>
              <h3 class="font-heading text-h3 font-semibold text-text">{service.title}</h3>
              <p class="mt-2 text-text-muted leading-relaxed">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
  <Footer slot="footer" />
</BaseLayout>